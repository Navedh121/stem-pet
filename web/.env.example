# ============================================================
# STEMPet — Environment Variables
# ============================================================
# Copy this file to ".env.local" and fill in your real values.
# NEVER commit .env.local to git — it contains secrets.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Get these from: Supabase dashboard → Project Settings → API

# Public URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon (public) key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER SIDE ONLY.
# Used by API routes to bypass RLS when logging toy data.
# NEVER prefix this with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Groq AI ──────────────────────────────────────────────────
# Get a free API key at: https://console.groq.com
# Used server-side only to generate math questions.
GROQ_API_KEY=your-groq-api-key-here
